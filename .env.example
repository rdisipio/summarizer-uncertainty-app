OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=summarizer-uncertainty-app
SHOW_UNCERTAINTY=true
# SHOW_LOGO must be either true or false.
SHOW_LOGO=true
UNCERTAINTY_THRESHOLD=50
# HuggingFace Space sentence uncertainty API.
HF_UNCERTAINTY_API_URL=https://rdisipio-sentence-uncertainty.hf.space/score
HF_UNCERTAINTY_SAMPLE_COUNT=20
